# ═══════════════════════════════════════
# GCP Agent Gateway — Environment Config
# ═══════════════════════════════════════

# ── GCP Project ──
GCP_PROJECT_ID=my-gcp-project

# ── Pub/Sub ──
PUBSUB_SUBSCRIPTIONS=earnings-summary-sub,risk-eval-sub
PUBSUB_RESULT_TOPIC=agent-results
PUBSUB_MAX_MESSAGES=1
PUBSUB_ACK_DEADLINE=600

# ── GCS Buckets ──
GCS_WORKSPACE_BUCKET=my-agent-workspaces
GCS_OUTPUT_BUCKET=my-agent-outputs
GCS_TASKLOG_BUCKET=my-agent-task-logs

# ── LLM API Keys ──
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Default LLM Model ──
DEFAULT_LLM_MODEL=claude-sonnet-4-20250514
DEFAULT_LLM_MAX_TOKENS=4096

# ── Agent Runtime ──
AGENT_MAX_ITERATIONS=10
SKILLS_BASE_PATH=/app/skills
WORKSPACE_TMP_DIR=/tmp/workspace

# ── GatewayServices Limits ──
MAX_READS_PER_SESSION=50
MAX_WRITES_PER_SESSION=20
MAX_PUBLISHES_PER_SESSION=10
MAX_FILE_READ_SIZE_MB=10

# ── Internal APIs (optional) ──
DATA_API_BASE_URL=https://data-api.internal.company.com
DATA_API_KEY=...

# ── Logging ──
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Gateway Version (auto-set by CI/CD) ──
GATEWAY_VERSION=0.3.0
