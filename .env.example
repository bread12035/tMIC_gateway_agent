# ═══════════════════════════════════════
# GCP Agent Gateway — Environment Config
# ═══════════════════════════════════════

# ── GCP Project ──
GCP_PROJECT_ID=my-gcp-project

# ── Pub/Sub ──
PUBSUB_SUBSCRIPTIONS=earnings-summary-sub,risk-eval-sub
PUBSUB_RESULT_TOPIC=agent-results
PUBSUB_MAX_MESSAGES=1
PUBSUB_ACK_DEADLINE=600

# ── GCS Buckets ──
GCS_WORKSPACE_BUCKET=my-agent-workspaces
GCS_OUTPUT_BUCKET=my-agent-outputs
GCS_TASKLOG_BUCKET=my-agent-task-logs

# ── LLM API Keys ──
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Default LLM Model ──
DEFAULT_LLM_MODEL=claude-sonnet-4-20250514
DEFAULT_LLM_MAX_TOKENS=4096

# ── Agent Runtime ──
AGENT_MAX_ITERATIONS=10
SKILLS_BASE_PATH=/app/skills
WORKSPACE_TMP_DIR=/tmp/workspace

# ── GatewayServices Limits ──
MAX_READS_PER_SESSION=50
MAX_WRITES_PER_SESSION=20
MAX_PUBLISHES_PER_SESSION=10
MAX_FILE_READ_SIZE_MB=10

# ── Internal APIs (optional) ──
DATA_API_BASE_URL=https://data-api.internal.company.com
DATA_API_KEY=...

# ── Logging ──
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── CronScheduler ──
CRON_SCHEDULER_ENABLED=true   # false = do not start (e.g. in test envs)

# ── External data-source URLs (mirrored in configmap.yaml) ──
# Primary URL for the pre-earnings prompt and the ECTS web-search branch.
# Supports {company} / {ticker} / {fiscal_year} / {fiscal_quarter} placeholders.
STOCKTITAN_URL=https://www.stocktitan.net/news/{ticker}
# Earnings-call transcript source for the ECTS web-search branch.
MOTLEYFOOL_URL=https://www.fool.com/earnings/call-transcripts/

# ── ECTS web-search switch ──
# "true" → ECTS prompt uses stocktitan + motley fool URLs above.
# "false" → ECTS prompt uses GCS-prefetched inputs/.
WEB_SEARCH_FLAG=false

# ── Pre-earnings fallbacks (used only when stocktitan lookup fails) ──
COMPANY_IR_URL=
COMPANY_TOPIC=

# ── Gateway Version (auto-set by CI/CD) ──
GATEWAY_VERSION=0.3.0
